# =====================================================
# BudsAI prototype — environment template
# Copy to .env (server/.env) and fill in real values.
# .env is gitignored.
# =====================================================

# ---- OpenAI (Sprint 2 이후) ----
OPENAI_API_KEY=sk-...
OPENAI_STT_MODEL=whisper-1
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# ---- Server ----
PORT=8000
LOG_LEVEL=info
ENV=development
# Comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://hyenem.github.io

# ---- Device auth (Sprint 1 이후) ----
# Demo shared secret; replaced by per-device pubkey registry later.
DEMO_DEVICE_ID=buds-demo-001
DEMO_DEVICE_SECRET=replace-me-with-long-random-string

# ---- Session / JWT (Sprint 1 이후) ----
JWT_SECRET=replace-me-with-another-long-random-string
JWT_TTL_SECONDS=3600
